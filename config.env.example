# ============================================================
# AI 小说矩阵工作室 — 配置模板文件
# 使用方法：
#   1. 复制此文件并重命名为 config.env
#   2. 填入你的真实账号和 API Key
#   3. config.env 已加入 .gitignore，不会上传到 Gitee
# ============================================================

# ── MySQL 数据库 ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=ai_novel_studio

# 完整连接 URL（后端异步用）
MYSQL_URL=mysql+aiomysql://root:your_password@localhost:3306/ai_novel_studio
# 完整连接 URL（GUI 同步用）
MYSQL_SYNC_URL=mysql+pymysql://root:your_password@localhost:3306/ai_novel_studio?charset=utf8mb4

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_novel_studio

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MiniMax（用于：选题生成）────────────────────────────────
# 申请地址：https://www.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# ── 豆包 Doubao（用于：大纲生成）────────────────────────────
# 申请地址：https://www.volcengine.com/product/doubao
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_ENDPOINT_ID=your_doubao_endpoint_id

# ── 通义千问 Qwen（用于：正文生成）──────────────────────────
# 申请地址：https://dashscope.aliyun.com/
QWEN_API_KEY=your_qwen_api_key

# ── DeepSeek（用于：内容润色）───────────────────────────────
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key

# ── Gitee 账号（用于版本管理，可选）─────────────────────────
GITEE_USERNAME=your_gitee_username
